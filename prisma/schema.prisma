generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id    String   @id @default(uuid())
  email String   @unique
  role  UserRole @default(USER)

  warningCount Int @default(0)

  isBanned     Boolean   @default(false)
  bannedAt     DateTime?
  bannedReason String?
}

enum AccessStatus {
  GRANTED
  DENIED_ROLE
  DENIED_UNAUTH
}

model AdminAccessLog {
  id        String       @id @default(cuid())
  email     String?
  userId    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime     @default(now())
  status    AccessStatus

  @@index([createdAt])
}

enum AdminActionType {
  WARN
  FINAL_WARN
  RESET_WARNINGS
  TEMP_BAN
  PERM_BAN
  UNBAN
}

model AdminActionsLog {
  id           String          @id @default(cuid())
  adminUserId  String
  targetUserId String?
  action       AdminActionType
  reason       String?
  createdAt    DateTime        @default(now())

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([createdAt])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdBy String
  createdAt DateTime @default(now())
}

enum RoastIntensity {
  mild
  medium
  savage
}

model RoastResult {
  id        String         @id @default(cuid())
  userId    String
  name      String
  bio       String
  intensity RoastIntensity
  result    String[]
  createdAt DateTime       @default(now())

  @@index([userId])
  @@index([createdAt])
}

model CacheTest {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  views     Int
}
