// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id    String   @id @default(uuid())
  email String   @unique
  role  UserRole @default(USER)
}

enum AccessStatus {
  GRANTED // Actual Admin
  DENIED_ROLE // Normal user tried to look
  DENIED_UNAUTH // Anonymous tried to look
}

model AdminAccessLog {
  id        String       @id @default(cuid())
  userId    String? // Optional, unauthenticated users have no ID
  email     String? // Optional, same reason
  ipAddress String?
  userAgent String?
  status    AccessStatus
  createdAt DateTime     @default(now())

  @@index([createdAt]) // Index to make sorting by date first
}

model Location {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdBy String
  createdAt DateTime @default(now())
}

enum RoastIntensity {
  mild
  medium
  savage
}

model RoastResult {
  id        String         @id @default(cuid())
  userId    String
  name      String
  bio       String
  intensity RoastIntensity
  result    String[]
  createdAt DateTime       @default(now())

  @@index([userId])
  @@index([createdAt])
}

model CacheTest {
  id        String   @id @default(cuid())
  title     String
  views     Int
  createdAt DateTime @default(now())
}
